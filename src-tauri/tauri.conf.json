{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhotoViewer",
  "version": "0.1.0",
  "identifier": "com.photoviewer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Photo Viewer",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["jpg", "jpeg"],
        "name": "JPEG Image",
        "description": "JPEG Image File",
        "mimeType": "image/jpeg"
      },
      {
        "ext": ["png"],
        "name": "PNG Image",
        "description": "PNG Image File",
        "mimeType": "image/png"
      },
      {
        "ext": ["heic", "heif"],
        "name": "HEIC Image",
        "description": "High Efficiency Image File",
        "mimeType": "image/heic"
      }
    ]
  }
}
